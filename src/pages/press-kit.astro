---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'sk';
const t = useTranslations(lang);
---

<BaseLayout title={t.pressKit.title} lang={lang}>
  <section class="section pt-24">
    <div class="container mx-auto max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-charcoal mb-4">{t.pressKit.title}</h1>
      <p class="text-xl text-cool-grey mb-12">{t.pressKit.subtitle}</p>

      <!-- Logos -->
      <div class="card mb-8">
        <h2 class="text-2xl font-heading font-semibold text-charcoal mb-2">{t.pressKit.logos}</h2>
        <p class="text-cool-grey mb-6">{t.pressKit.logosDesc}</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div class="bg-pale-circle-light rounded-xl p-6 flex flex-col items-center">
            <img src="/logonobg.png" alt="BlavFF Logo" class="w-32 h-32 object-contain mb-4" />
            <p class="text-cool-grey text-sm mb-3">PNG — Transparent background</p>
            <a href="/logonobg.png" download class="btn btn-secondary text-sm">
              {t.pressKit.download}
            </a>
          </div>
          <div class="bg-charcoal rounded-xl p-6 flex flex-col items-center">
            <img src="/logowb.png" alt="BlavFF Logo White" class="w-32 h-32 object-contain mb-4" />
            <p class="text-cool-grey-light text-sm mb-3">PNG — White version</p>
            <a href="/logowb.png" download class="btn btn-secondary text-sm">
              {t.pressKit.download}
            </a>
          </div>
        </div>
      </div>

      <!-- Posters -->
      <div class="card mb-8">
        <h2 class="text-2xl font-heading font-semibold text-charcoal mb-2">{t.pressKit.posters}</h2>
        <p class="text-cool-grey mb-6">{t.pressKit.postersDesc}</p>
        <div class="bg-pale-circle-light rounded-xl p-8 text-center">
          <p class="text-cool-grey">{lang === 'sk' ? 'Plagáty budú čoskoro k dispozícii.' : 'Posters will be available soon.'}</p>
        </div>
      </div>

      <!-- Brand Guidelines -->
      <div class="card bg-pale-circle-light/50">
        <h2 class="text-2xl font-heading font-semibold text-charcoal mb-2">{t.pressKit.brandGuidelines}</h2>
        <p class="text-cool-grey">{t.pressKit.brandGuidelinesDesc}</p>
      </div>
    </div>
  </section>
</BaseLayout>
