---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'sk';
const t = useTranslations(lang);
---

<BaseLayout title={t.competitions.title} lang={lang}>
  <section class="section pt-24">
    <div class="container mx-auto max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-charcoal mb-4">{t.competitions.title}</h1>
      <p class="text-xl text-cool-grey mb-12">{t.competitions.subtitle}</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Fursuit / Costume -->
        <div class="card border-2 border-icy-cyan">
          <div class="text-5xl mb-4">🐾</div>
          <h2 class="text-2xl font-heading font-semibold text-charcoal mb-3">{t.competitions.fursuit.title}</h2>
          <p class="text-cool-grey text-lg leading-relaxed mb-6">{t.competitions.fursuit.desc}</p>
          <a href="/prihlasky" class="btn btn-primary w-full justify-center">{t.competitions.fursuit.signup}</a>
        </div>

        <!-- Art -->
        <div class="card border-2 border-warm-brown">
          <div class="text-5xl mb-4">🎨</div>
          <h2 class="text-2xl font-heading font-semibold text-charcoal mb-3">{t.competitions.art.title}</h2>
          <p class="text-cool-grey text-lg leading-relaxed mb-6">{t.competitions.art.desc}</p>
          <a href="/prihlasky" class="btn btn-warm w-full justify-center">{t.competitions.art.signup}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
