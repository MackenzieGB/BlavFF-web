---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'sk';
const t = useTranslations(lang);

const artists = [
  // Add artists here:
  // { name: 'Artist Name', role: 'Illustrátor / Illustrator', avatar: '/artists/artist-slug.png', socials: [{ platform: 'instagram', url: 'https://instagram.com/...' }, { platform: 'website', url: 'https://...' }] },
];
---

<BaseLayout title={t.artistAlley.title} lang={lang}>
  <section class="section pt-24">
    <div class="container mx-auto max-w-5xl">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-charcoal mb-4">{t.artistAlley.title}</h1>
      <p class="text-xl text-cool-grey mb-12">{t.artistAlley.subtitle}</p>

      <div class="card mb-8">
        <h2 class="text-2xl font-heading font-semibold text-charcoal mb-4">{t.artistAlley.whatIs}</h2>
        <p class="text-cool-grey text-lg leading-relaxed">{t.artistAlley.whatIsDesc}</p>
      </div>

      <h2 class="text-2xl font-heading font-semibold text-charcoal mb-6">{t.artistAlley.attending}</h2>
      {artists.length > 0 ? (
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 mb-8">
          {artists.map((artist) => (
            <div class="card text-center">
              <div class="w-20 h-20 mx-auto mb-3 rounded-full bg-pale-circle flex items-center justify-center overflow-hidden">
                {artist.avatar ? (
                  <img src={artist.avatar} alt={artist.name} class="w-full h-full object-cover" />
                ) : (
                  <span class="text-2xl font-heading font-bold text-icy-cyan">{artist.name.charAt(0)}</span>
                )}
              </div>
              <h3 class="font-heading font-semibold text-charcoal">{artist.name}</h3>
              <p class="text-cool-grey text-sm">{artist.role}</p>
              {artist.socials && artist.socials.length > 0 && (
                <div class="flex justify-center gap-2 mt-2">
                  {artist.socials.map((social) => (
                    <a href={social.url} target="_blank" rel="noopener" class="text-cool-grey hover:text-icy-cyan transition-colors" aria-label={social.platform}>
                      {social.platform === 'instagram' && (
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                      )}
                      {social.platform === 'website' && (
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/></svg>
                      )}
                    </a>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      ) : (
        <div class="card text-center py-12 mb-8">
          <p class="text-cool-grey text-lg">{t.artistAlley.noArtists}</p>
        </div>
      )}

      <div class="text-center">
        <a href="/prihlasky" class="btn btn-primary text-lg px-8 py-3">
          {lang === 'sk' ? 'Prihlásiť sa do Artist Alley' : 'Apply for Artist Alley'}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
