---
import BaseLayout from '../layouts/BaseLayout.astro';
import MascotCallout from '../components/MascotCallout.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'sk';
const t = useTranslations(lang);
---

<BaseLayout title={t.register.title} lang={lang}>
  <link rel="stylesheet" type="text/css" href="https://tickets.furosion.com/furosion/blavff/widget/v2.css" crossorigin />
  <script type="text/javascript" src="https://tickets.furosion.com/widget/v2.sk.js" async crossorigin></script>

  <section class="section pt-24">
    <div class="container mx-auto max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-charcoal mb-4">{t.register.title}</h1>
      <p class="text-xl text-cool-grey mb-12">{t.register.subtitle}</p>

      <!-- Ticket Types -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
        <div class="card border-2 border-pale-circle">
          <div class="text-3xl mb-4">🎫</div>
          <h3 class="font-heading font-semibold text-xl text-charcoal mb-2">{t.register.ticketFree}</h3>
          <p class="text-cool-grey mb-4">{t.register.ticketFreeDesc}</p>
          <p class="font-heading font-bold text-2xl text-icy-cyan">{t.register.ticketFreePrice}</p>
        </div>

        <div class="card border-2 border-warm-brown relative">
          <div class="absolute -top-3 right-4 bg-warm-brown text-surface text-sm font-heading font-semibold px-3 py-1 rounded-full">
            {lang === 'sk' ? 'Odporúčané' : 'Recommended'}
          </div>
          <div class="text-3xl mb-4">⭐</div>
          <h3 class="font-heading font-semibold text-xl text-charcoal mb-2">{t.register.ticketSupporter}</h3>
          <p class="text-cool-grey mb-4">{t.register.ticketSupporterDesc}</p>
          <p class="font-heading font-bold text-2xl text-warm-brown">{t.register.ticketSupporterPrice}</p>
        </div>
      </div>

      <!-- Age Note -->
      <MascotCallout text={t.home.ageNote} variant="warning" class="mb-8" />

      <!-- ToS Gate -->
      <div class="card bg-pale-circle-light/50 mb-8">
        <label class="flex items-start gap-3 cursor-pointer">
          <input type="checkbox" id="tos-agree" class="mt-1 w-5 h-5 rounded border-cool-grey text-icy-cyan focus:ring-icy-cyan" />
          <span class="text-charcoal">
            {t.register.tosAgree} <a href="/tos" class="text-icy-cyan hover:text-icy-cyan-dark underline">{t.register.tosLink}</a>.
            <span class="block text-sm text-cool-grey mt-1">{t.register.tosRequired}</span>
          </span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer mt-4">
          <input type="checkbox" id="age-confirm" class="mt-1 w-5 h-5 rounded border-cool-grey text-icy-cyan focus:ring-icy-cyan" />
          <span class="text-charcoal">{t.register.ageConfirm}</span>
        </label>
      </div>

      <!-- Pretix Widget -->
      <div class="card">
        <h2 class="font-heading font-semibold text-xl text-charcoal mb-4">{t.register.widgetTitle}</h2>
        <pretix-widget event="https://tickets.furosion.com/furosion/blavff/"></pretix-widget>
        <noscript>
          <div class="pretix-widget">
            <div class="pretix-widget-info-message">
              JavaScript is disabled in your browser. To access our ticket shop without JavaScript, please <a target="_blank" rel="noopener" href="https://tickets.furosion.com/furosion/blavff/">click here</a>.
            </div>
          </div>
        </noscript>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const tosCheckbox = document.getElementById('tos-agree');
  const ageCheckbox = document.getElementById('age-confirm');
  const pretixWidget = document.querySelector('pretix-widget');

  function updateWidget() {
    if (pretixWidget) {
      if (tosCheckbox.checked && ageCheckbox.checked) {
        pretixWidget.style.opacity = '1';
        pretixWidget.style.pointerEvents = 'auto';
      } else {
        pretixWidget.style.opacity = '0.4';
        pretixWidget.style.pointerEvents = 'none';
      }
    }
  }

  if (tosCheckbox && ageCheckbox) {
    tosCheckbox.addEventListener('change', updateWidget);
    ageCheckbox.addEventListener('change', updateWidget);
    updateWidget();
  }
</script>
