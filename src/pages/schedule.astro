---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScheduleTable from '../components/ScheduleTable.astro';
import MascotCallout from '../components/MascotCallout.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'sk';
const t = useTranslations(lang);

const scheduleItems = [
  { time: '9:30', title: t.schedule.placeholder1, description: t.schedule.placeholder1Desc, location: 'Hlavná sála' },
  { time: '10:00', title: t.schedule.placeholder2, description: t.schedule.placeholder2Desc, location: 'Panelová miestnosť' },
  { time: '11:00', title: t.schedule.placeholder3, description: t.schedule.placeholder3Desc, location: 'Workshop miestnosť' },
  { time: '12:00', title: t.schedule.placeholder4, description: t.schedule.placeholder4Desc, location: '—' },
  { time: '13:30', title: t.schedule.placeholder5, description: t.schedule.placeholder5Desc, location: 'Hlavná sála' },
  { time: '15:00', title: t.schedule.placeholder6, description: t.schedule.placeholder6Desc, location: 'Panelová miestnosť' },
  { time: '16:00', title: t.schedule.placeholder7, description: t.schedule.placeholder7Desc, location: 'Hlavná sála' },
  { time: '17:30', title: t.schedule.placeholder8, description: t.schedule.placeholder8Desc, location: 'Hlavná sála' },
  { time: '19:00', title: t.schedule.placeholder9, description: t.schedule.placeholder9Desc, location: 'Hlavná sála' },
];
---

<BaseLayout title={t.schedule.title} lang={lang}>
  <section class="section pt-24">
    <div class="container mx-auto max-w-5xl">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-charcoal mb-4">{t.schedule.title}</h1>
      <p class="text-xl text-cool-grey mb-4">{t.schedule.subtitle}</p>
      <MascotCallout text={t.schedule.note} variant="info" class="mb-8" />

      <ScheduleTable items={scheduleItems} lang={lang} />
    </div>
  </section>
</BaseLayout>
