---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
---

<BaseLayout title={t.volunteer.title} lang={lang}>
  <section class="section pt-24">
    <div class="container mx-auto max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-charcoal mb-4">{t.volunteer.title}</h1>
      <p class="text-xl text-cool-grey mb-12">{t.volunteer.subtitle}</p>

      <div class="card mb-8">
        <p class="text-cool-grey text-lg leading-relaxed">{t.volunteer.description}</p>
      </div>

      <div class="card bg-icy-cyan/10 border-2 border-icy-cyan">
        <h2 class="text-2xl font-heading font-semibold text-charcoal mb-4">{t.volunteer.signupBtn}</h2>
        <p class="text-cool-grey text-lg leading-relaxed mb-6">{t.volunteer.signupDesc}</p>
        <button data-fillout-id="von2aiWAw7us" data-fillout-embed-type="popup" data-fillout-dynamic-resize data-fillout-inherit-parameters data-fillout-popup-size="medium" class="btn btn-primary">
          {t.volunteer.signupBtn}
        </button>
      </div>
    </div>
  </section>

  <script src="https://server.fillout.com/embed/v1/" is:inline></script>
</BaseLayout>
