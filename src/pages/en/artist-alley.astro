---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MascotCallout from '../../components/MascotCallout.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const rules = [
  t.artistAlley.rule1,
  t.artistAlley.rule2,
  t.artistAlley.rule3,
  t.artistAlley.rule4,
  t.artistAlley.rule5,
];
---

<BaseLayout title={t.artistAlley.title} lang={lang}>
  <section class="section pt-24">
    <div class="container mx-auto max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-charcoal mb-4">{t.artistAlley.title}</h1>
      <p class="text-xl text-cool-grey mb-12">{t.artistAlley.subtitle}</p>

      <div class="card mb-8">
        <h2 class="text-2xl font-heading font-semibold text-charcoal mb-4">{t.artistAlley.whatIs}</h2>
        <p class="text-cool-grey text-lg leading-relaxed">{t.artistAlley.whatIsDesc}</p>
      </div>

      <div class="card bg-icy-cyan/10 border-2 border-icy-cyan mb-8">
        <h2 class="text-2xl font-heading font-semibold text-charcoal mb-4">{t.artistAlley.apply}</h2>
        <p class="text-cool-grey text-lg leading-relaxed mb-4">{t.artistAlley.applyDesc}</p>
        <button data-fillout-id="4896Rg9V8jus" data-fillout-embed-type="popup" data-fillout-dynamic-resize data-fillout-inherit-parameters data-fillout-popup-size="medium" class="btn btn-primary">
          {t.artistAlley.applyBtn}
        </button>
      </div>

      <div class="card mb-8">
        <h2 class="text-2xl font-heading font-semibold text-charcoal mb-4">{t.artistAlley.rules}</h2>
        <ul class="space-y-3">
          {rules.map((rule) => (
            <li class="flex items-start gap-3 text-cool-grey">
              <span class="text-icy-cyan font-bold mt-0.5">✕</span>
              {rule}
            </li>
          ))}
        </ul>
      </div>

      <h2 class="text-2xl font-heading font-semibold text-charcoal mb-6">{t.artistAlley.attending}</h2>
      <div class="card text-center py-12">
        <p class="text-cool-grey text-lg">{t.artistAlley.noArtists}</p>
      </div>
    </div>
  </section>

  <script src="https://server.fillout.com/embed/v1/" is:inline></script>
</BaseLayout>
