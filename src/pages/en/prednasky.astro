---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MascotCallout from '../../components/MascotCallout.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const speakers = [];

const examples = [
  'Talk about the furry community',
  'Drawing workshop',
  'Therian identity panel',
  'Cosplay tutorial',
  'Anything you\'re passionate about!',
];
---

<BaseLayout title={t.prednasky.title} lang={lang}>
  <section class="section pt-24">
    <div class="container mx-auto max-w-5xl">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-charcoal mb-4">{t.prednasky.title}</h1>
      <p class="text-xl text-cool-grey mb-12">{t.prednasky.subtitle}</p>

      <p class="text-cool-grey text-lg leading-relaxed mb-8">{t.prednasky.description}</p>

      {speakers.length > 0 ? (
        <div class="mb-12">
          <h2 class="text-2xl font-heading font-semibold text-charcoal mb-6">{t.prednasky.speakers}</h2>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            {speakers.map((speaker) => (
              <div class="card text-center">
                <div class="w-20 h-20 mx-auto mb-3 rounded-full bg-pale-circle flex items-center justify-center overflow-hidden">
                  {speaker.avatar ? (
                    <img src={speaker.avatar} alt={speaker.name} class="w-full h-full object-cover" />
                  ) : (
                    <span class="text-2xl font-heading font-bold text-icy-cyan">{speaker.name.charAt(0)}</span>
                  )}
                </div>
                <h3 class="font-heading font-semibold text-charcoal">{speaker.name}</h3>
                <p class="text-cool-grey text-sm">{speaker.role}</p>
                {speaker.socials && speaker.socials.length > 0 && (
                  <div class="flex justify-center gap-2 mt-2">
                    {speaker.socials.map((social) => (
                      <a href={social.url} target="_blank" rel="noopener" class="text-cool-grey hover:text-icy-cyan transition-colors">
                        {social.platform === 'instagram' && (
                          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                        )}
                        {social.platform === 'twitter' && (
                          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                        )}
                        {social.platform === 'website' && (
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/></svg>
                        )}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      ) : (
        <div class="card text-center py-12 mb-12">
          <p class="text-cool-grey text-lg">{t.prednasky.noSpeakers}</p>
        </div>
      )}

      <div class="card bg-icy-cyan/10 border-2 border-icy-cyan text-center">
        <h2 class="text-2xl font-heading font-semibold text-charcoal mb-4">{t.prednasky.wantToPresent}</h2>
        <p class="text-cool-grey text-lg mb-4">{t.prednasky.wantToPresentDesc}</p>
        <div class="flex flex-wrap justify-center gap-2 mb-6">
          {examples.map((ex) => (
            <span class="bg-pale-circle text-charcoal text-sm px-3 py-1 rounded-full">{ex}</span>
          ))}
        </div>
        <button data-fillout-id="4hpwcoJXxAus" data-fillout-embed-type="popup" data-fillout-dynamic-resize data-fillout-inherit-parameters data-fillout-popup-size="medium" class="btn btn-primary">
          {t.prednasky.applyNow}
        </button>
      </div>
    </div>
  </section>

  <script src="https://server.fillout.com/embed/v1/" is:inline></script>
</BaseLayout>
