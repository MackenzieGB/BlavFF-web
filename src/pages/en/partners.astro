---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const partners = [
  { name: 'Youth Hub', url: 'https://www.instagram.com/bratislavska_platforma_mladych/', description: 'BlavFF venue' },
];
---

<BaseLayout title={t.partners.title} lang={lang}>
  <section class="section pt-24">
    <div class="container mx-auto max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-charcoal mb-4">{t.partners.title}</h1>
      <p class="text-xl text-cool-grey mb-12">{t.partners.subtitle}</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {partners.map((partner) => (
          <a href={partner.url} target="_blank" rel="noopener" class="card flex items-center gap-4 group hover:border-icy-cyan transition-colors">
            <div class="w-16 h-16 rounded-xl bg-pale-circle flex items-center justify-center flex-shrink-0">
              <span class="text-2xl font-heading font-bold text-icy-cyan">{partner.name.charAt(0)}</span>
            </div>
            <div>
              <h3 class="font-heading font-semibold text-lg text-charcoal group-hover:text-icy-cyan transition-colors">{partner.name}</h3>
              <p class="text-cool-grey text-sm">{partner.description}</p>
            </div>
          </a>
        ))}
      </div>

      <div class="card bg-warm-brown/10 border-2 border-warm-brown mt-12 text-center">
        <h2 class="text-2xl font-heading font-semibold text-charcoal mb-4">{t.partners.becomePartner}</h2>
        <p class="text-cool-grey text-lg mb-6">{t.partners.becomePartnerDesc}</p>
        <a href="mailto:hello@furosion.org?subject=Partner Inquiry" class="btn btn-warm">{t.partners.contactUs}</a>
      </div>
    </div>
  </section>
</BaseLayout>
