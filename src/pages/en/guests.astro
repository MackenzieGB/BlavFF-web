---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
---

<BaseLayout title={t.guests.title} lang={lang}>
  <section class="section pt-24">
    <div class="container mx-auto max-w-5xl">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-charcoal mb-4">{t.guests.title}</h1>
      <p class="text-xl text-cool-grey mb-12">{t.guests.subtitle}</p>

      <div class="card text-center py-12 mb-8">
        <p class="text-cool-grey text-lg">{t.guests.noGuests}</p>
      </div>

      <div class="text-center">
        <a href="/en/prihlasky" class="btn btn-warm text-lg px-8 py-3">{lang === 'en' ? 'Apply to Present' : 'Prihlásiť sa'}</a>
      </div>
    </div>
  </section>
</BaseLayout>
