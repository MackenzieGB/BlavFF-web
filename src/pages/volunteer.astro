---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'sk';
const t = useTranslations(lang);
---

<BaseLayout title={t.volunteer.title} lang={lang}>
  <section class="section pt-24">
    <div class="container mx-auto max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-charcoal mb-4">{t.volunteer.title}</h1>
      <p class="text-xl text-cool-grey mb-12">{t.volunteer.subtitle}</p>

      <div class="card mb-8">
        <p class="text-cool-grey text-lg leading-relaxed">{t.volunteer.description}</p>
      </div>

      <div class="text-center">
        <a href="/prihlasky" class="btn btn-primary text-lg px-8 py-3">{t.volunteer.signupBtn}</a>
      </div>
    </div>
  </section>
</BaseLayout>
