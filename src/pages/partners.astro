---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'sk';
const t = useTranslations(lang);

// ADD NEW PARTNERS HERE — just copy/paste a new object:
// { name: 'Partner Name', logo: '/partners/partner-slug.png', url: 'https://...' },
// Logos are automatically centered in the grid.
const partners = [
  { name: 'Youth Hub', logo: '/partners/youth-hub.png', url: 'https://www.youthhub.sk/' },
];
---

<BaseLayout title={t.partners.title} lang={lang}>
  <section class="section pt-24">
    <div class="container mx-auto max-w-5xl">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-charcoal mb-4">{t.partners.title}</h1>
      <p class="text-xl text-cool-grey mb-12">{t.partners.subtitle}</p>

      <!-- Partner logos — automatically centered -->
      <div class="flex flex-wrap justify-center items-center gap-8 mb-12">
        {partners.map((partner) => (
          <a href={partner.url} target="_blank" rel="noopener" class="partner-logo w-48 h-32">
            <img src={partner.logo} alt={partner.name} loading="lazy" />
          </a>
        ))}
      </div>

      <!-- Partner inquiry -->
      <div class="card bg-charcoal text-surface text-center">
        <h2 class="text-2xl font-heading font-semibold text-icy-cyan mb-4">{t.partners.becomePartner}</h2>
        <p class="text-cool-grey-light text-lg mb-6 max-w-xl mx-auto">{t.partners.becomePartnerDesc}</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="mailto:support@furosion.com?subject=Partner Inquiry" class="btn btn-primary">
            {t.partners.contactUs}
          </a>
          <a href="https://www.furosion.org" target="_blank" rel="noopener" class="btn btn-secondary">
            furosion.org
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
