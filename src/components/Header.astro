---
import { useTranslations } from '../i18n/utils';
import logo from '../assets/logonobg.png';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as 'sk' | 'en');
const isSk = lang === 'sk';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-surface/90 backdrop-blur-md border-b border-pale-circle">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <a href={isSk ? '/' : '/en/'} class="flex items-center gap-2">
        <img src={logo.src} alt="BlavFF Logo" class="h-10 w-auto" />
        <span class="font-heading font-bold text-xl text-charcoal">BlavFF</span>
      </a>

      <nav class="hidden md:flex items-center gap-6">
        <a href={isSk ? '/about' : '/en/about'} class="text-cool-grey hover:text-icy-cyan transition-colors font-medium">{t.nav.about}</a>
        <a href={isSk ? '/schedule' : '/en/schedule'} class="text-cool-grey hover:text-icy-cyan transition-colors font-medium">{t.nav.schedule}</a>
        <a href={isSk ? '/prednasky' : '/en/prednasky'} class="text-cool-grey hover:text-icy-cyan transition-colors font-medium">{t.nav.prednasky}</a>
        <a href={isSk ? '/artist-alley' : '/en/artist-alley'} class="text-cool-grey hover:text-icy-cyan transition-colors font-medium">{t.nav.artistAlley}</a>
        <a href={isSk ? '/guests' : '/en/guests'} class="text-cool-grey hover:text-icy-cyan transition-colors font-medium">{t.nav.guests}</a>
        <a href={isSk ? '/volunteer' : '/en/volunteer'} class="text-cool-grey hover:text-icy-cyan transition-colors font-medium">{t.nav.volunteer}</a>
        <a href={isSk ? '/venue' : '/en/venue'} class="text-cool-grey hover:text-icy-cyan transition-colors font-medium">{t.nav.venue}</a>
        <a href={isSk ? '/partners' : '/en/partners'} class="text-cool-grey hover:text-icy-cyan transition-colors font-medium">{t.nav.partners}</a>
      </nav>

      <div class="flex items-center gap-3">
        <a href={isSk ? '/en' + Astro.url.pathname.replace(/\/sk/, '') : Astro.url.pathname.replace(/\/en/, '') || '/'} class="text-cool-grey hover:text-icy-cyan transition-colors font-medium text-sm px-2 py-1 rounded-md border border-pale-circle">
          {isSk ? 'EN' : 'SK'}
        </a>
        <a href={isSk ? '/register' : '/en/register'} class="btn btn-primary text-sm py-2 px-4">{t.nav.register}</a>

        <button id="mobile-menu-btn" class="md:hidden p-2 text-charcoal" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-surface border-t border-pale-circle">
    <nav class="flex flex-col p-4 gap-3">
      <a href={isSk ? '/about' : '/en/about'} class="text-cool-grey hover:text-icy-cyan transition-colors font-medium py-2">{t.nav.about}</a>
      <a href={isSk ? '/schedule' : '/en/schedule'} class="text-cool-grey hover:text-icy-cyan transition-colors font-medium py-2">{t.nav.schedule}</a>
      <a href={isSk ? '/prednasky' : '/en/prednasky'} class="text-cool-grey hover:text-icy-cyan transition-colors font-medium py-2">{t.nav.prednasky}</a>
      <a href={isSk ? '/artist-alley' : '/en/artist-alley'} class="text-cool-grey hover:text-icy-cyan transition-colors font-medium py-2">{t.nav.artistAlley}</a>
      <a href={isSk ? '/guests' : '/en/guests'} class="text-cool-grey hover:text-icy-cyan transition-colors font-medium py-2">{t.nav.guests}</a>
      <a href={isSk ? '/volunteer' : '/en/volunteer'} class="text-cool-grey hover:text-icy-cyan transition-colors font-medium py-2">{t.nav.volunteer}</a>
      <a href={isSk ? '/venue' : '/en/venue'} class="text-cool-grey hover:text-icy-cyan transition-colors font-medium py-2">{t.nav.venue}</a>
      <a href={isSk ? '/partners' : '/en/partners'} class="text-cool-grey hover:text-icy-cyan transition-colors font-medium py-2">{t.nav.partners}</a>
      <a href={isSk ? '/news' : '/en/news'} class="text-cool-grey hover:text-icy-cyan transition-colors font-medium py-2">{t.nav.news}</a>
      <a href={isSk ? '/register' : '/en/register'} class="btn btn-primary mt-2">{t.nav.register}</a>
    </nav>
  </div>
</header>

<script is:inline>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
