---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as 'sk' | 'en');
const isSk = lang === 'sk';
---

<footer class="bg-charcoal text-surface">
  <!-- Main footer content -->
  <div class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/logowb.png" alt="BlavFF Logo" class="h-14 w-auto" />
          <div>
            <span class="font-heading font-bold text-xl block">BlavFF</span>
            <span class="text-cool-grey text-xs">{isSk ? 'Bratislava FluffFest' : 'Bratislava FluffFest'}</span>
          </div>
        </div>
        <p class="text-cool-grey text-sm leading-relaxed">
          {isSk
            ? 'Mini festival pre furry, therianov a cosplay komunitu. Organizované Furosion o.z.'
            : 'Mini festival for the furry, therian, and cosplay community. Organized by Furosion o.z.'}
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="font-heading font-semibold mb-4 text-icy-cyan">{isSk ? 'Navigácia' : 'Navigation'}</h3>
        <div class="grid grid-cols-2 gap-2 text-sm">
          <a href={isSk ? '/about' : '/en/about'} class="text-cool-grey-light hover:text-icy-cyan transition-colors py-1">{t.nav.about}</a>
          <a href={isSk ? '/schedule' : '/en/schedule'} class="text-cool-grey-light hover:text-icy-cyan transition-colors py-1">{t.nav.schedule}</a>
          <a href={isSk ? '/register' : '/en/register'} class="text-cool-grey-light hover:text-icy-cyan transition-colors py-1">{t.nav.register}</a>
          <a href={isSk ? '/rules' : '/en/rules'} class="text-cool-grey-light hover:text-icy-cyan transition-colors py-1">{t.nav.rules}</a>
          <a href={isSk ? '/artist-alley' : '/en/artist-alley'} class="text-cool-grey-light hover:text-icy-cyan transition-colors py-1">{t.nav.artistAlley}</a>
          <a href={isSk ? '/prednasky' : '/en/prednasky'} class="text-cool-grey-light hover:text-icy-cyan transition-colors py-1">{isSk ? 'Prednášky' : 'Talks'}</a>
          <a href={isSk ? '/guests' : '/en/guests'} class="text-cool-grey-light hover:text-icy-cyan transition-colors py-1">{t.nav.guests}</a>
          <a href={isSk ? '/volunteer' : '/en/volunteer'} class="text-cool-grey-light hover:text-icy-cyan transition-colors py-1">{t.nav.volunteer}</a>
          <a href={isSk ? '/venue' : '/en/venue'} class="text-cool-grey-light hover:text-icy-cyan transition-colors py-1">{t.nav.venue}</a>
          <a href={isSk ? '/partners' : '/en/partners'} class="text-cool-grey-light hover:text-icy-cyan transition-colors py-1">{t.nav.partners}</a>
        </div>
      </div>

      <!-- Social -->
      <div>
        <h3 class="font-heading font-semibold mb-4 text-icy-cyan">{isSk ? 'Sleduj nás' : 'Follow Us'}</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href="https://www.instagram.com/furosionorg" target="_blank" rel="noopener" class="text-cool-grey-light hover:text-icy-cyan transition-colors flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              @furosionorg
            </a>
          </li>
          <li>
            <a href="https://www.tiktok.com/@furosionorg" target="_blank" rel="noopener" class="text-cool-grey-light hover:text-icy-cyan transition-colors flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/></svg>
              @furosionorg
            </a>
          </li>
          <li>
            <a href="https://whatsapp.com/channel/0029Vb7S2UhGzzKKmLhHMt3f" target="_blank" rel="noopener" class="text-cool-grey-light hover:text-icy-cyan transition-colors flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
              WhatsApp
            </a>
          </li>
          <li>
            <a href="https://www.instagram.com/bratislavska_platforma_mladych/" target="_blank" rel="noopener" class="text-cool-grey-light hover:text-icy-cyan transition-colors flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              BPM (Youth Hub)
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Legal links bar -->
    <div class="border-t border-charcoal-light pt-6 flex flex-wrap justify-center gap-6 text-sm">
      <a href={isSk ? '/privacy' : '/en/privacy'} class="text-cool-grey-light hover:text-icy-cyan transition-colors">{t.footer.privacy}</a>
      <a href={isSk ? '/tos' : '/en/tos'} class="text-cool-grey-light hover:text-icy-cyan transition-colors">{t.footer.tos}</a>
      <a href={isSk ? '/rules' : '/en/rules'} class="text-cool-grey-light hover:text-icy-cyan transition-colors">{t.footer.rules}</a>
    </div>
  </div>

  <!-- Furosion attribution -->
  <div class="border-t border-charcoal-light py-8">
    <div class="text-center">
      <a href="https://furosion.org" target="_blank" rel="noopener" class="inline-block text-decoration-none no-underline">
        <img src="https://furosion.org/furosionozsquare.png" alt="Furosion logo" class="w-[60px] h-[60px] block mx-auto mb-2 animate-float" />
        <div class="text-cool-grey text-sm animate-fade">
          {isSk ? 'Projekt organizácie Furosion o.z.' : 'A Furosion o.z. project'}
        </div>
      </a>
    </div>
  </div>

  <!-- Copyright bar -->
  <div class="bg-charcoal-light/30 py-4">
    <div class="container mx-auto px-4 text-center text-cool-grey text-xs">
      {isSk
        ? '© 2026 BlavFF — Furosion o.z. Všetky práva vyhradené. | Tomášikova 45/A, Bratislava | IČO: 57528900'
        : '© 2026 BlavFF — Furosion o.z. All rights reserved. | Tomášikova 45/A, Bratislava | IČO: 57528900'}
    </div>
  </div>
</footer>
